# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secretos; .env.example sí se puede commitear)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# prisma
prisma/migrations/**/migration_lock.toml

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / OS
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
Thumbs.db
*.log

# ayuda local (clave SSH para copiar a GitHub)
GITHUB_SSH_KEY.txt
