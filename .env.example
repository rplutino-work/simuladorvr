# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth v4 ──────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://tu-dominio.vercel.app"
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="genera-un-secreto-seguro-aqui"
NEXTAUTH_SECRET="el-mismo-valor-que-AUTH_SECRET"
AUTH_TRUST_HOST="true"

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Credenciales de producción (APP_USR-...) → isSandbox queda en false
# Credenciales de prueba (TEST-...) → poner NEXT_PUBLIC_MERCADOPAGO_SANDBOX=true
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxx-xxxxxx-xxxxxxxxx-xxxxxxxxxx"
# Descomenta si usas credenciales TEST-
# NEXT_PUBLIC_MERCADOPAGO_SANDBOX="true"

# ─── Resend (emails transaccionales) ─────────────────────────────────────────
# Obtener en https://resend.com → Dashboard → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Para producción verificá tu dominio en Resend. En testing usá:
# EMAIL_FROM="Simulador VR <onboarding@resend.dev>"
EMAIL_FROM="Simulador VR <noreply@tudominio.com>"
EMAIL_FALLBACK="admin@tudominio.com"

# ─── Cron Jobs (Vercel) ───────────────────────────────────────────────────────
# Opcional: protege el endpoint /api/cron/expire-bookings
# CRON_SECRET="genera-un-token-aleatorio"
